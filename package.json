{
  "name": "washraum-app",
  "version": "0.1.0",
  "private": true,
  "description": "Web-App zur Verwaltung von Waschraum-Buchungen.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "health": "node -e \"fetch('http://localhost:3000/api/health').then(r=>r.json()).then(console.log).catch(err=>{console.error(err);process.exit(1)})\"",
    "bookings": "node -e \"fetch('http://localhost:3000/api/bookings').then(r=>r.json()).then(console.log).catch(err=>{console.error(err);process.exit(1)})\"",
    "verify": "node --check server.js && node --check public/app.js && node --check public/login.js && node --check scripts/smoke-test.js && node --check scripts/twenty-party-test.js && node --check scripts/full-app-test.js && node --check scripts/hosting-check.js && node --check scripts/production-check.js && node --check scripts/publish-check.js && node --check scripts/pilot-readiness-check.js && npm run hosting:check",
    "smoke": "node scripts/smoke-test.js",
    "test:20-parties": "node scripts/twenty-party-test.js",
    "test:full": "node scripts/full-app-test.js",
    "hosting:check": "node scripts/hosting-check.js",
    "publish:check": "node scripts/publish-check.js",
    "pilot:check": "node scripts/pilot-readiness-check.js",
    "production:check": "node scripts/production-check.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "express": "^4.18.3"
  },
  "engines": {
    "node": "22.12.0"
  }
}
